---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SharePanel from '../../components/SharePanel.astro';
import ScrollToTop from '../../components/ScrollToTop.astro';
import PostPrevNext from '../../components/PostPrevNext.astro';
import { useTranslations } from '../../i18n/utils';
import { TTSPlayer } from '../../components/TTSPlayer';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { getSeriesNav } from '../../utils/seriesNav';
import { calcReadingTime } from '../../utils/readingTime';
import { getOgImageUrl } from '../../lib/shareCard';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh-TW');
  const allPosts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const t = useTranslations('zh-TW');
const related = getRelatedPosts(post, allPosts);
const series = getSeriesNav(post, allPosts);
const readingTime = post.data.readingTime ?? calcReadingTime(post.body ?? '');
const ogImage = getOgImageUrl(Astro.url.pathname, Astro.url.origin) ?? undefined;

// Calculate Prev/Next
const sortedPosts = allPosts
  .filter(p => !p.data.draft && p.data.lang === 'zh-TW')
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": post.data.title,
  "description": post.data.description ?? post.data.tldr,
  "datePublished": post.data.date.toISOString(),
  "keywords": post.data.tags.join(", "),
};

const dateStr = post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description} jsonLd={jsonLd} layout="article" ogImage={ogImage}>
  <!-- Full-bleed Hero Banner -->
  <header class="post-hero" style={`--cat-color: var(--cat-${post.data.category});`}>
    <!-- OG Background Layer -->
    <div class="hero-bg-wrapper">
      {ogImage && (
        <img 
          src={ogImage} 
          alt="" 
          class="hero-bg-img"
          onerror="this.style.display='none'"
        />
      )}
      <div class="hero-bg-overlay"></div>
    </div>

    <div class="hero-inner">
      <div class="hero-content">
        <div class="hero-meta">
          <a href={`/categories/${post.data.category}`} class="hero-badge">{post.data.category}</a>
          <time class="hero-date">{dateStr}</time>
          <span class="hero-sep">·</span>
          <span class="hero-reading">{readingTime} 分鐘閱讀</span>
          <span class="hero-sep">·</span>
          <span id="view-count" class="hero-views">－ 次閱讀</span>
        </div>

        <h1 class="hero-title">{post.data.title}</h1>

        {post.data.tldr && (
          <div class="hero-tldr">
            <p class="tldr-label">{t('post.tldr')}</p>
            <p class="tldr-content">{post.data.tldr}</p>
          </div>
        )}
      </div>
    </div>

    <!-- Wave Separator -->
    <div class="hero-wave">
      <svg data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="shape-fill"></path>
      </svg>
    </div>
  </header>

  <div class="article-grid">
  <article class="article-body">
    <div class="article-share-panel">
      <SharePanel title={post.data.title} url={Astro.url.href} imageUrl={ogImage ?? ''} />
    </div>

    <!-- Series nav (top) -->
    {series && (
      <div style="background:var(--bg-secondary); border:0.5px solid var(--separator); border-radius:var(--radius-md); padding:14px 18px; margin-bottom:28px; font-size:13px;">
        <p style="margin:0 0 8px; font-weight:600; color:var(--label-secondary); text-transform:uppercase; letter-spacing:0.05em; font-size:11px;">
          系列：{series.name}（{series.current}/{series.total}）
        </p>
        <div style="display:flex; justify-content:space-between; gap:12px;">
          {series.prev
            ? <a href={`/posts/${series.prev.id}`} style="color:var(--accent); text-decoration:none; font-size:13px;">← {series.prev.title}</a>
            : <span />}
          {series.next && <a href={`/posts/${series.next.id}`} style="color:var(--accent); text-decoration:none; font-size:13px;">{series.next.title} →</a>}
        </div>
      </div>
    )}

    <!-- Table of Contents -->
    {tocHeadings.length > 2 && (
      <details class="toc-block toc-mobile" open>
        <summary>目錄</summary>
        <nav>
          <ol>
            {tocHeadings.map(h => (
              <li style={h.depth === 3 ? 'margin-left:1.2em;' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </details>
    )}

    <!-- TTS Player -->
    <TTSPlayer 
      client:load 
      title={post.data.title} 
      tldr={post.data.tldr} 
      content={post.body ?? ''}
      initialAudioUrl={post.data.audio_url}
      initialSrtUrl={post.data.srt_url}
    />

    <!-- Content -->
    <div class="prose"><Content /></div>

    <!-- Prev/Next Nav -->
    <PostPrevNext 
      prev={prevPost ? { id: prevPost.id, title: prevPost.data.title } : undefined} 
      next={nextPost ? { id: nextPost.id, title: nextPost.data.title } : undefined} 
    />

    <!-- Tags -->
    {post.data.tags.length > 0 && (
      <div style="margin-top:40px; padding-top:24px; border-top:0.5px solid var(--separator);">
        <p style="font-size:11px; color:var(--label-tertiary); margin:0 0 10px; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">{t('post.tags')}</p>
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      </div>
    )}

    <!-- Related posts -->
    {related.length > 0 && (
      <div style="margin-top:48px; padding-top:32px; border-top:0.5px solid var(--separator);">
        <h3 style="font-size:13px; color:var(--label-secondary); margin:0 0 16px; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">相關文章</h3>
        <div class="feed">
          {related.map((p) => (
            <PostCard
              id={p.id}
              title={p.data.title}
              date={p.data.date}
              category={p.data.category}
              tags={p.data.tags}
              tldr={p.data.tldr}
              description={p.data.description}
              lang="zh-TW"
            />
          ))}
        </div>
      </div>
    )}
  </article>

  {tocHeadings.length > 2 && (
    <aside class="article-toc-sidebar">
      <div class="sidebar-block">
        <p class="toc-sidebar-title">目錄</p>
        <ol>
          {tocHeadings.map(h => (
            <li class={h.depth === 3 ? 'toc-item toc-item--sub' : 'toc-item'}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ol>
      </div>
    </aside>
  )}
  </div>
</BaseLayout>

<style>
  .post-hero {
    position: relative;
    padding: 100px 24px 120px;
    background: var(--bg);
    overflow: hidden;
    margin-bottom: 40px;
    border-bottom: 0.5px solid var(--separator);
  }

  .hero-bg-wrapper {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(60px) saturate(1.8);
    opacity: 0.45;
    transform: scale(1.1);
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg, 
      color-mix(in srgb, var(--cat-color) 15%, transparent) 0%, 
      var(--bg) 100%
    );
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .hero-badge {
    background: var(--cat-color);
    color: #fff;
    padding: 2px 10px;
    border-radius: var(--radius-full);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
  }

  .hero-date, .hero-reading, .hero-views {
    font-size: 13px;
    color: var(--label-secondary);
    font-variant-numeric: tabular-nums;
  }

  .hero-sep {
    color: var(--label-tertiary);
    opacity: 0.5;
  }

  .hero-title {
    font-size: clamp(28px, 6vw, 44px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
    color: var(--label);
  }

  .hero-tldr {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    border-left: 4px solid var(--cat-color);
    border-radius: var(--radius-md);
    padding: 20px 24px;
    max-width: 680px;
  }

  .tldr-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--cat-color);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 8px;
  }

  .tldr-content {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--label-secondary);
  }

  .hero-wave {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    transform: rotate(180deg);
  }

  .hero-wave svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 48px;
  }

  .hero-wave .shape-fill {
    fill: var(--bg);
  }

  .article-grid { display: block; }

  .article-share-panel {
    display: block;
    margin-bottom: 24px;
  }

  @media (min-width: 1140px) {
    .article-grid {
      display: grid;
      grid-template-columns: 1fr 240px;
      gap: 56px;
      align-items: start;
      max-width: 1100px;
      margin: 0 auto;
    }
    .toc-mobile { display: none; }
  }

  .article-toc-sidebar { display: none; }

  @media (min-width: 1140px) {
    .article-toc-sidebar {
      display: flex;
      flex-direction: column;
      gap: 24px;
      position: sticky;
      top: 110px;
      max-height: calc(100vh - 140px);
      overflow-y: auto;
      padding: 0;
      background: transparent;
      border: none;
    }
  }

  .sidebar-block {
    background: var(--bg-secondary);
    border: 0.5px solid var(--separator);
    border-radius: var(--radius-md);
    padding: 14px 16px;
  }

  .toc-sidebar-title {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--label-secondary);
    margin: 0 0 10px;
  }

  .article-toc-sidebar ol { padding: 0; margin: 0; list-style: none; }
  .toc-item { position: relative; }
  .toc-item + .toc-item { margin-top: 8px; }
  .toc-item--sub { padding-left: 14px; }
  .toc-item--sub::before {
    content: '';
    position: absolute;
    left: 4px; top: 10px;
    width: 4px; height: 1px;
    background: var(--label-tertiary);
    opacity: 0.5;
  }

  .article-toc-sidebar a {
    color: var(--label-secondary);
    text-decoration: none;
    line-height: 1.4;
    transition: all 0.15s ease;
    display: block;
    font-size: 13px;
  }
  .article-toc-sidebar a:hover {
    color: var(--accent);
    transform: translateX(2px);
  }
</style>

<script define:vars={{ slug: post.id }}>
  (async () => {
    try {
      const res = await fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug }),
      });
      const { count } = await res.json();
      const el = document.getElementById('view-count');
      if (el && count) el.textContent = `${count.toLocaleString()} 次閱讀`;
    } catch {
      // D1 不可用時靜默失敗，不影響頁面
    }
  })();
</script>

<ScrollToTop />
