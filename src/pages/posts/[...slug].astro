---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { useTranslations } from '../../i18n/utils';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { getSeriesNav } from '../../utils/seriesNav';
import { calcReadingTime } from '../../utils/readingTime';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh-TW');
  const allPosts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
const t = useTranslations('zh-TW');
const related = getRelatedPosts(post, allPosts);
const series = getSeriesNav(post, allPosts);
const readingTime = post.data.readingTime ?? calcReadingTime(post.body ?? '');

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": post.data.title,
  "description": post.data.description ?? post.data.tldr,
  "datePublished": post.data.date.toISOString(),
  "keywords": post.data.tags.join(", "),
};

const dateStr = post.data.date.toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={post.data.title} description={post.data.description} jsonLd={jsonLd}>
  <article>
    <!-- Header -->
    <header style="padding: 40px 0 28px; border-bottom: 0.5px solid var(--separator); margin-bottom: 36px;">
      <div style="margin-bottom: 10px;">
        <a href={`/categories/${post.data.category}`} class="badge badge-type" style="text-decoration:none;">{post.data.category}</a>
      </div>

      <h1 style="margin:0 0 20px; font-size:clamp(26px,5vw,36px); font-weight:900; line-height:1.15; letter-spacing:-0.02em;">{post.data.title}</h1>

      <div style="display:flex; align-items:center; gap:6px; font-size:13px; color:var(--label-secondary); flex-wrap:wrap;">
        <time style="font-variant-numeric: tabular-nums;">{dateStr}</time>
        <span style="opacity:0.35;">·</span>
        <span>{readingTime} 分鐘閱讀</span>
        <span style="opacity:0.35;">·</span>
        <span id="view-count">－ 次閱讀</span>
        {post.data.type && (
          <>
            <span style="opacity:0.35;">·</span>
            <span class="badge badge-type">{post.data.type}</span>
          </>
        )}
      </div>

      {post.data.tldr && (
        <div style="background:color-mix(in srgb, var(--accent) 7%, transparent); border:0.5px solid color-mix(in srgb, var(--accent) 20%, transparent); border-left:3px solid var(--accent); border-radius:var(--radius-md); padding:16px 20px; margin-top:24px;">
          <p style="font-size:11px; font-weight:700; color:var(--accent); margin:0 0 6px; text-transform:uppercase; letter-spacing:0.06em;">{t('post.tldr')}</p>
          <p style="margin:0; font-size:15px; color:var(--label); line-height:1.7;">{post.data.tldr}</p>
        </div>
      )}
    </header>

    <!-- Series nav (top) -->
    {series && (
      <div style="background:var(--bg-secondary); border:0.5px solid var(--separator); border-radius:var(--radius-md); padding:14px 18px; margin-bottom:28px; font-size:13px;">
        <p style="margin:0 0 8px; font-weight:600; color:var(--label-secondary); text-transform:uppercase; letter-spacing:0.05em; font-size:11px;">
          系列：{series.name}（{series.current}/{series.total}）
        </p>
        <div style="display:flex; justify-content:space-between; gap:12px;">
          {series.prev
            ? <a href={`/posts/${series.prev.id}`} style="color:var(--accent); text-decoration:none; font-size:13px;">← {series.prev.title}</a>
            : <span />}
          {series.next && <a href={`/posts/${series.next.id}`} style="color:var(--accent); text-decoration:none; font-size:13px;">{series.next.title} →</a>}
        </div>
      </div>
    )}

    <!-- Table of Contents -->
    {tocHeadings.length > 2 && (
      <details class="toc-block" open>
        <summary>目錄</summary>
        <nav>
          <ol>
            {tocHeadings.map(h => (
              <li style={h.depth === 3 ? 'margin-left:1.2em;' : ''}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </details>
    )}

    <!-- Content -->
    <div class="prose"><Content /></div>

    <!-- Tags -->
    {post.data.tags.length > 0 && (
      <div style="margin-top:40px; padding-top:24px; border-top:0.5px solid var(--separator);">
        <p style="font-size:11px; color:var(--label-tertiary); margin:0 0 10px; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">{t('post.tags')}</p>
        <div class="tags">
          {post.data.tags.map((tag) => (
            <a href={`/tags/${tag}`} class="tag">#{tag}</a>
          ))}
        </div>
      </div>
    )}

    <!-- Related posts -->
    {related.length > 0 && (
      <div style="margin-top:48px; padding-top:32px; border-top:0.5px solid var(--separator);">
        <h3 style="font-size:13px; color:var(--label-secondary); margin:0 0 16px; text-transform:uppercase; letter-spacing:0.05em; font-weight:600;">相關文章</h3>
        <div class="feed">
          {related.map((p) => (
            <PostCard
              id={p.id}
              title={p.data.title}
              date={p.data.date}
              category={p.data.category}
              tags={p.data.tags}
              tldr={p.data.tldr}
              description={p.data.description}
              lang="zh-TW"
            />
          ))}
        </div>
      </div>
    )}
  </article>
</BaseLayout>

<script define:vars={{ slug: post.id }}>
  (async () => {
    try {
      const res = await fetch('/api/views', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug }),
      });
      const { count } = await res.json();
      const el = document.getElementById('view-count');
      if (el && count) el.textContent = `${count.toLocaleString()} 次閱讀`;
    } catch {
      // D1 不可用時靜默失敗，不影響頁面
    }
  })();
</script>
