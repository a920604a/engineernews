---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="post-content">
    <div style="margin-bottom: 2rem;">
      <h1 style="margin-bottom: 0.5rem;">{post.data.title}</h1>
      <div style="color: var(--label-secondary); font-size: 14px; margin-bottom: 1rem;">
        {post.data.date.toLocaleDateString('zh-TW')} · {post.data.category}
        {post.data.type && <span style="margin-left: 8px;">· {post.data.type}</span>}
      </div>

      {post.data.tldr && (
        <div class="card" style="background: var(--glass-bg); border-left: 4px solid var(--accent-color);">
          <h3 style="margin-top: 0; font-size: 16px;">TL;DR</h3>
          <p style="margin-bottom: 0; font-size: 15px;">{post.data.tldr}</p>
        </div>
      )}
    </div>

    <div class="markdown-body">
      <Content />
    </div>

    <div style="margin-top: 4rem; padding-top: 2rem; border-top: 0.5px solid var(--separator);">
      <h3 style="font-size: 14px; color: var(--label-secondary); margin-bottom: 1rem;">相關標籤</h3>
      <div class="tags">
        {post.data.tags.map((tag) => (
          <a href={`/tags/${tag}`} class="tag">#{tag}</a>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .markdown-body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--label-primary);
  }
  .markdown-body h2 {
    margin-top: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 0.5px solid var(--separator);
  }
  .markdown-body pre {
    background: #1c1c1e;
    padding: 16px;
    border-radius: 12px;
    overflow-x: auto;
    border: 0.5px solid var(--separator);
  }
  .markdown-body code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    font-size: 0.9em;
  }
</style>
