---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('posts', ({ data }) =>
  !data.draft && data.type === 'case-study' && data.lang === 'zh-TW'
);
const sorted = posts.sort((a, b) => {
  if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
  return a.data.title.localeCompare(b.data.title);
});
---

<BaseLayout title="Portfolio">
  <section>
    <h1>Portfolio</h1>
    <p style="color: var(--label-secondary); margin-bottom: 2rem;">
      Side projects and personal work.
    </p>

    <div style="display: grid; gap: 1.5rem;">
      {sorted.map((post) => (
        <div class="card">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 0.5rem;">
            <h2 style="margin: 0; font-size: 20px;">{post.data.title}</h2>
            <div style="display: flex; gap: 0.5rem;">
              {post.data.github && (
                <a href={post.data.github} target="_blank" rel="noopener" class="btn-primary" style="font-size: 12px;">
                  GitHub
                </a>
              )}
              {post.data.url && (
                <a href={post.data.url} target="_blank" rel="noopener" class="btn-primary" style="font-size: 12px;">
                  Website
                </a>
              )}
              <a href={`/posts/${post.id}`} class="btn-primary" style="font-size: 12px;">
                View
              </a>
            </div>
          </div>
          <p style="margin: 0.75rem 0; color: var(--label-secondary); font-size: 15px;">
            {post.data.description}
          </p>
          <div class="tags">
            {post.data.tags.map((tag) => (
              <span class="tag">#{tag}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
