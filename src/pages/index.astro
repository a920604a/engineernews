---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search';
import PostCard from '../components/PostCard.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('zh-TW');

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh-TW');
const allProjects = await getCollection('projects');

function projectDescription(description) {
  return typeof description === 'string' ? description : (description && description.background) ? description.background : '';
}

type FeedItem =
  | { kind: 'post'; pinned: boolean; date: Date; post: (typeof allPosts)[number] }
  | { kind: 'project'; pinned: boolean; date: Date | undefined; project: (typeof allProjects)[number] };

const feed: FeedItem[] = [
  ...allPosts.map((p) => ({ kind: 'post' as const, pinned: p.data.pinned, date: p.data.date, post: p })),
  ...allProjects.map((p) => ({ kind: 'project' as const, pinned: p.data.pinned, date: p.data.date, project: p })),
];

feed.sort((a, b) => {
  if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
  const aTime = a.date?.valueOf() ?? 0;
  const bTime = b.date?.valueOf() ?? 0;
  return bTime - aTime;
});
---

<BaseLayout title={t('nav.home')}>
  <section style="padding-top: 40px;">
    <p style="font-size:15px; color:var(--label-secondary); margin:0 0 32px; line-height:1.6;">
      {t('site.tagline')}
    </p>

    <Search client:load />

    {feed.length === 0 ? (
      <div style="border: 0.5px dashed var(--separator); padding: 40px; text-align: center; border-radius: var(--radius-lg); color: var(--label-secondary);">
        <p style="margin:0;">{t('feed.empty')}</p>
      </div>
    ) : (
      <div class="feed">
        {feed.map((item) =>
          item.kind === 'post' ? (
            <PostCard
              id={item.post.id}
              title={item.post.data.title}
              date={item.post.data.date}
              category={item.post.data.category}
              tags={item.post.data.tags}
              description={item.post.data.description}
              tldr={item.post.data.tldr}
              type={item.post.data.type}
              pinned={item.post.data.pinned}
              readingTime={item.post.data.readingTime}
              lang="zh-TW"
            />
          ) : (
            <article class="postcard">
              <div class="postcard-meta">
                <div class="postcard-badges">
                  {item.project.data.pinned && <span class="badge badge-pinned">置頂</span>}
                  <span class="badge badge-project">專案</span>
                </div>
              </div>
              <h2 class="postcard-title">
                <a href={`/projects/${item.project.id}`}>{item.project.data.title}</a>
              </h2>
              <p class="postcard-excerpt">{projectDescription(item.project.data.description)}</p>
              {(item.project.data.tags || []).length > 0 && (
                <div class="postcard-tags">
                  {item.project.data.tags.map((tag) => (
                    <a href={`/tags/${tag}`} class="postcard-tag">#{tag}</a>
                  ))}
                </div>
              )}
            </article>
          )
        )}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .badge-project {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    background: color-mix(in srgb, var(--color-orange, #ff9f0a) 12%, transparent);
    color: var(--color-orange, #ff9f0a);
    border: 0.5px solid color-mix(in srgb, var(--color-orange, #ff9f0a) 30%, transparent);
  }
</style>
