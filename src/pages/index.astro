---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('zh-TW');

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh-TW');
const allProjects = await getCollection('projects');

function projectDesc(description: unknown): string {
  if (typeof description === 'string') return description;
  if (description && typeof description === 'object' && 'background' in description) {
    return (description as { background: string }).background ?? '';
  }
  return '';
}

type FeedItem =
  | { kind: 'post'; pinned: boolean; date: Date; item: (typeof allPosts)[number] }
  | { kind: 'project'; pinned: boolean; date: Date | undefined; item: (typeof allProjects)[number] };

const feed: FeedItem[] = [
  ...allPosts.map((p) => ({ kind: 'post' as const, pinned: !!p.data.pinned, date: p.data.date, item: p })),
  ...allProjects.map((p) => ({ kind: 'project' as const, pinned: !!p.data.pinned, date: p.data.date, item: p })),
];

feed.sort((a, b) => {
  if (a.pinned !== b.pinned) return a.pinned ? -1 : 1;
  return (b.date?.valueOf() ?? 0) - (a.date?.valueOf() ?? 0);
});
---

<BaseLayout title={t('nav.home')}>
  <section style="padding-top: 40px;">
    <p style="font-size:15px; color:var(--label-secondary); margin:0 0 36px; line-height:1.7;">
      {t('site.tagline')}
    </p>

    {feed.length === 0 ? (
      <div style="border: 0.5px dashed var(--separator); padding: 48px; text-align: center; border-radius: var(--radius-lg); color: var(--label-secondary);">
        <p style="margin:0;">{t('feed.empty')}</p>
      </div>
    ) : (
      <div class="card-grid">
        {feed.map((entry) =>
          entry.kind === 'post' ? (
            <PostCard
              id={entry.item.id}
              title={entry.item.data.title}
              date={entry.item.data.date}
              category={entry.item.data.category}
              tags={entry.item.data.tags}
              description={entry.item.data.description}
              tldr={entry.item.data.tldr}
              type={entry.item.data.type}
              pinned={entry.item.data.pinned}
              readingTime={entry.item.data.readingTime}
              lang="zh-TW"
              kind="post"
            />
          ) : (
            <PostCard
              id={entry.item.id}
              title={entry.item.data.title}
              date={entry.item.data.date}
              category={entry.item.data.category ?? 'project'}
              tags={entry.item.data.tags ?? []}
              description={projectDesc(entry.item.data.description)}
              pinned={entry.item.data.pinned}
              lang="zh-TW"
              kind="project"
            />
          )
        )}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  @media (max-width: 520px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
