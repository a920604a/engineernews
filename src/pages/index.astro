---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search';
import PostCard from '../components/PostCard.astro';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('zh-TW');

const allPosts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh-TW');
const posts = allPosts.sort((a, b) => {
  if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
  return b.data.date.valueOf() - a.data.date.valueOf();
});

const allProjects = await getCollection('projects');
const projects = allProjects
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return a.data.title.localeCompare(b.data.title);
  })
  .slice(0, 4);

function projectDescription(description) {
  return typeof description === 'string' ? description : (description && description.background) ? description.background : '';
}
---

<BaseLayout title={t('nav.home')}>
  <section style="padding-top: 40px;">
    <p style="font-size:15px; color:var(--label-secondary); margin:0 0 32px; line-height:1.6;">
      {t('site.tagline')}
    </p>

    <Search client:load />

    {posts.length === 0 ? (
      <div style="border: 0.5px dashed var(--separator); padding: 40px; text-align: center; border-radius: var(--radius-lg); color: var(--label-secondary);">
        <p style="margin:0;">{t('feed.empty')}</p>
      </div>
    ) : (
      <>
        <div class="feed">
          {posts.map((post) => (
            <PostCard
              id={post.id}
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              tags={post.data.tags}
              description={post.data.description}
              tldr={post.data.tldr}
              type={post.data.type}
              pinned={post.data.pinned}
              readingTime={post.data.readingTime}
              lang="zh-TW"
            />
          ))}
        </div>

        <section style="margin-top: 40px;">
          <h2 style="margin:0 0 12px;">最新專案</h2>
          <div style="display:grid; gap:1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
            {projects.map((project) => (
              <div class="card">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:0.5rem;">
                  <h3 style="margin:0; font-size:16px;">{project.data.title}</h3>
                  <div style="display:flex; gap:0.5rem;">
                    {project.data.github && (
                      <a href={project.data.github} target="_blank" rel="noopener" class="btn-primary" style="font-size:12px;">GitHub</a>
                    )}
                    {project.data.url && (
                      <a href={project.data.url} target="_blank" rel="noopener" class="btn-primary" style="font-size:12px;">網站</a>
                    )}
                  </div>
                </div>

                <p style="margin:0.5rem 0; color:var(--label-secondary);">{projectDescription(project.data.description)}</p>

                <div style="display:flex; justify-content:space-between; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                  <div class="tags">{(project.data.tags || []).map((tag) => <span class="tag">#{tag}</span>)}</div>
                  <a href={`/projects/${project.id}`} style="font-size:13px; color:var(--accent-color); text-decoration:none;">查看 →</a>
                </div>
              </div>
            ))}
          </div>
        </section>
      </>
    )}
  </section>
</BaseLayout>
