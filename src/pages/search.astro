---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="搜尋">
  <section class="search-page">
    <h1>搜尋</h1>
    <p class="search-intro">
      用關鍵字直接找文章內容 &mdash; 或試試 <a href="/ai-search">AI 語義搜尋</a>
    </p>

    <div class="search-shell card">
      <div class="search-shell-head">
        <span class="search-shell-label">全文關鍵字搜尋</span>
        <span class="search-shell-hint">Pagefind</span>
      </div>

      <form id="search-form" class="search-form">
        <label class="sr-only" for="search-input">搜尋文章</label>
        <div class="search-input-wrap">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <path d="M20 20l-3.5-3.5" />
          </svg>
          <input
            id="search-input"
            class="search-input"
            type="search"
            name="q"
            placeholder="搜尋文章、標題、技術名詞..."
            autocomplete="off"
            spellcheck="false"
          />
        </div>
        <button class="search-button" type="submit">搜尋</button>
      </form>

      <p id="search-status" class="search-status">輸入關鍵字後按 Enter。</p>
      <div id="search-results" class="search-results" aria-live="polite"></div>
    </div>
  </section>
</BaseLayout>

<script is:inline type="module">
  const form = document.getElementById('search-form');
  const input = document.getElementById('search-input');
  const status = document.getElementById('search-status');
  const results = document.getElementById('search-results');

  if (!form || !input || !status || !results) {
    throw new Error('Search UI failed to mount');
  }

  let pagefindModule = null;
  let searchTimer = null;
  let requestId = 0;

  const escapeHtml = (value) =>
    String(value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

  const normalizeUrl = (url) => {
    if (!url) return '#';
    return url.startsWith('http') ? url : url.startsWith('/') ? url : `/${url}`;
  };

  const renderEmpty = (message) => {
    results.innerHTML = '';
    status.textContent = message;
  };

  const renderResults = (items, query) => {
    if (!items.length) {
      results.innerHTML = `
        <div class="search-empty card">
          <p class="search-empty-title">找不到「${escapeHtml(query)}」的相關結果</p>
          <p class="search-empty-text">換個關鍵字，或試試更具體的技術名詞。</p>
        </div>
      `;
      status.textContent = '沒有命中結果。';
      return;
    }

    status.textContent = `找到 ${items.length} 筆結果。`;
    results.innerHTML = items.map((item, index) => {
      const data = item?.data ?? item;
      const meta = data?.meta ?? {};
      const url = normalizeUrl(data?.url ?? item?.url);
      const title = escapeHtml(meta?.title || meta?.name || '未命名文章');
      const excerpt = escapeHtml(data?.excerpt || data?.content || '');
      const date = escapeHtml(meta?.date || '');
      const category = escapeHtml(meta?.category || '');

      return `
        <a class="search-result card" href="${escapeHtml(url)}">
          <div class="search-result-top">
            <div class="search-result-badges">
              <span class="search-result-index">${index + 1}</span>
              ${category ? `<span class="search-result-badge">${category}</span>` : ''}
            </div>
            ${date ? `<span class="search-result-date">${date}</span>` : ''}
          </div>
          <h2 class="search-result-title">${title}</h2>
          ${excerpt ? `<p class="search-result-excerpt">${excerpt}</p>` : ''}
        </a>
      `;
    }).join('');
  };

  const loadPagefind = async () => {
    if (pagefindModule) return pagefindModule;

    try {
      pagefindModule = await import('/pagefind/pagefind.js');
      await pagefindModule.init();
      return pagefindModule;
    } catch (error) {
      console.error('Pagefind index not available', error);
      renderEmpty('全文索引尚未載入。請先執行 `pnpm build` 後再搜尋。');
      return null;
    }
  };

  const runSearch = async (rawQuery) => {
    const query = rawQuery.trim();
    const currentRequest = ++requestId;

    if (!query) {
      renderEmpty('輸入關鍵字後按 Enter。');
      return;
    }

    status.textContent = '搜尋中...';
    results.innerHTML = '';

    const pagefind = await loadPagefind();
    if (!pagefind?.search) return;

    try {
      const response = await pagefind.search(query);
      if (currentRequest !== requestId) return;

      const items = await Promise.all((response?.results ?? []).slice(0, 8).map(async (result) => {
        try {
          return await result.data();
        } catch (error) {
          console.warn('Failed to load Pagefind result data', error);
          return null;
        }
      }));
      renderResults(items.filter(Boolean), query);
    } catch (error) {
      console.error('Search failed', error);
      if (currentRequest !== requestId) return;
      renderEmpty('搜尋失敗，請稍後再試。');
    }
  };

  form.addEventListener('submit', (event) => {
    event.preventDefault();
    runSearch(input.value);
  });

  input.addEventListener('input', () => {
    window.clearTimeout(searchTimer);
    searchTimer = window.setTimeout(() => runSearch(input.value), 300);
  });

  if (input.value.trim()) {
    runSearch(input.value);
  }
</script>

<style is:global>
  .search-page {
    padding-top: 40px;
  }

  .search-page h1 {
    font-size: 28px;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 8px;
  }

  .search-intro {
    font-size: 15px;
    line-height: 1.7;
    color: var(--label-secondary);
    margin: 0 0 24px;
  }

  .search-shell {
    padding: 20px;
  }

  .search-shell-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }

  .search-shell-label,
  .search-shell-hint {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .search-shell-label {
    color: var(--label-secondary);
  }

  .search-shell-hint {
    color: var(--accent);
  }

  .search-form {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .search-input-wrap {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    width: 18px;
    height: 18px;
    transform: translateY(-50%);
    color: var(--label-tertiary);
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
  }

  .search-input {
    width: 100%;
    height: 50px;
    border-radius: 10px;
    border: 0.5px solid var(--separator);
    background: var(--bg-secondary);
    color: var(--label);
    padding: 0 14px 0 42px;
    font-size: 15px;
    outline: none;
  }

  .search-input::placeholder {
    color: var(--label-tertiary);
  }

  .search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 18%, transparent);
  }

  .search-button {
    height: 50px;
    padding: 0 16px;
    border-radius: 10px;
    border: 0.5px solid var(--accent);
    background: var(--accent);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
  }

  .search-status {
    margin: 12px 0 0;
    font-size: 13px;
    color: var(--label-secondary);
  }

  .search-results {
    display: grid;
    gap: 12px;
    margin-top: 16px;
  }

  .search-result {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 16px 18px;
    border-radius: 12px;
  }

  .search-result-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 8px;
  }

  .search-result-badges {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .search-result-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    background: var(--glass);
    color: var(--label-secondary);
    font-size: 12px;
    font-weight: 700;
  }

  .search-result-badge {
    display: inline-flex;
    align-items: center;
    height: 22px;
    padding: 0 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .search-result-date {
    font-size: 12px;
    color: var(--label-tertiary);
  }

  .search-result-title {
    margin: 0;
    font-size: 17px;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .search-result-excerpt {
    margin: 8px 0 0;
    color: var(--label-secondary);
    font-size: 13px;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .search-empty {
    margin-top: 8px;
    padding: 18px;
    border-radius: 12px;
    background: var(--bg-secondary);
  }

  .search-empty-title {
    margin: 0 0 6px;
    font-size: 15px;
    font-weight: 700;
  }

  .search-empty-text {
    margin: 0;
    color: var(--label-secondary);
    font-size: 13px;
    line-height: 1.6;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 640px) {
    .search-form {
      flex-direction: column;
      align-items: stretch;
    }

    .search-button {
      width: 100%;
    }
  }
</style>
