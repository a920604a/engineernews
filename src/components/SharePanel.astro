---
interface Props {
  title: string;
  url: string;
  imageUrl: string;
}

const { title, url, imageUrl } = Astro.props;
---

<section class="share-panel" data-share-panel data-share-title={title} data-share-url={url} data-share-image={imageUrl} aria-label="分享功能">
  <div class="share-panel__actions">
    <button type="button" class="share-panel__button share-panel__button--primary" data-share-native aria-label="分享">
      <svg class="share-panel__icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M13.5 5H19v5.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M19 5 10 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M8 7H6.5A2.5 2.5 0 0 0 4 9.5v8A2.5 2.5 0 0 0 6.5 20h8A2.5 2.5 0 0 0 17 17.5V16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>分享</span>
    </button>
    <button type="button" class="share-panel__button" data-share-copy aria-label="複製連結">
      <svg class="share-panel__icon" viewBox="0 0 24 24" aria-hidden="true">
        <rect x="9" y="9" width="10" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
        <path d="M7 15H6a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v1" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>複製</span>
    </button>
    <a class="share-panel__button share-panel__button--ghost" data-share-download href={imageUrl} download aria-label="下載圖卡">
      <svg class="share-panel__icon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 3v10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="m8 11 4 4 4-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M5 19h14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </a>
  </div>

  <p class="share-panel__sr-only" data-share-status aria-live="polite"></p>
</section>

<script type="module">
  const panel = document.querySelector('[data-share-panel]');

  if (panel) {
    const title = panel.dataset.shareTitle ?? document.title;
    const url = panel.dataset.shareUrl ?? window.location.href;
    const imageUrl = panel.dataset.shareImage ?? '';
    const status = panel.querySelector('[data-share-status]');
    const nativeButton = panel.querySelector('[data-share-native]');
    const copyButton = panel.querySelector('[data-share-copy]');
    const downloadButton = panel.querySelector('[data-share-download]');

    const setStatus = (message) => {
      if (status) status.textContent = message;
    };

    const toDownloadName = (value) =>
      `${value || 'share-card'}`
        .trim()
        .replace(/[\\/:*?"<>|]+/g, '-')
        .replace(/\s+/g, ' ')
        .slice(0, 120);

    const copyText = async (text) => {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return;
      }

      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.setAttribute('readonly', '');
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      textarea.remove();
    };

    nativeButton?.addEventListener('click', async () => {
      try {
        if (navigator.share) {
          await navigator.share({ title, url, text: title });
          setStatus('已開啟原生分享面板');
          return;
        }

        await copyText(url);
        setStatus('已複製連結');
      } catch (error) {
        console.error('Native share failed', error);
        setStatus('分享失敗，改用複製連結');
      }
    });

    copyButton?.addEventListener('click', async () => {
      try {
        await copyText(url);
        setStatus('已複製連結');
      } catch (error) {
        console.error('Copy link failed', error);
        setStatus('複製失敗');
      }
    });

    downloadButton?.addEventListener('click', async (event) => {
      event.preventDefault();

      if (!imageUrl) {
        setStatus('圖卡網址不可用');
        return;
      }

      try {
        setStatus('開始下載圖卡');
        const response = await fetch(imageUrl, { credentials: 'same-origin' });

        if (!response.ok) {
          throw new Error(`OG download failed: ${response.status}`);
        }

        const blob = await response.blob();
        const objectUrl = URL.createObjectURL(blob);
        const tempLink = document.createElement('a');
        tempLink.href = objectUrl;
        tempLink.download = `${toDownloadName(title)}.png`;
        tempLink.rel = 'noopener';
        document.body.appendChild(tempLink);
        tempLink.click();
        tempLink.remove();
        window.setTimeout(() => URL.revokeObjectURL(objectUrl), 1000);
        setStatus('已開始下載圖卡');
      } catch (error) {
        console.error('Download failed', error);
        setStatus('下載失敗');
      }
    });
  }
</script>

<style>
  .share-panel {
    margin: 0 0 20px;
    padding: 10px;
    border: 0.5px solid var(--separator);
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top right, color-mix(in srgb, var(--accent) 18%, transparent), transparent 34%),
      var(--bg-secondary);
    box-shadow: var(--shadow-md);
  }

  .share-panel__actions {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .share-panel__button {
    appearance: none;
    border: 0.5px solid var(--separator);
    background: transparent;
    color: var(--label);
    border-radius: var(--radius-full);
    padding: 10px 6px;
    font: inherit;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    min-height: 56px;
  }

  .share-panel__button:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
  }

  .share-panel__button--primary {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .share-panel__button--primary:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
  }

  .share-panel__button--ghost {
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  .share-panel__icon {
    width: 18px;
    height: 18px;
    flex: none;
  }

  .share-panel__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
