---
import type { Lang } from '../i18n/ui';

interface Props {
  id: string;
  title: string;
  date: Date;
  category: string;
  tags: string[];
  description?: string;
  tldr?: string;
  type?: string;
  pinned?: boolean;
  readingTime?: number;
  lang?: Lang;
  github?: string;
  url?: string;
  featured?: boolean;
}

const {
  id, title, date, category, tags,
  description, tldr, type, pinned = false,
  readingTime, lang = 'zh-TW',
  github, url, featured = false,
} = Astro.props;

const isEn = lang === 'en';
const postHref = isEn ? `/en/posts/${id}` : `/posts/${id}`;
const catHref  = isEn ? `/en/categories/${category}` : `/categories/${category}`;
const tagHref  = (t: string) => isEn ? `/en/tags/${t}` : `/tags/${t}`;

const dateStr = date?.toLocaleDateString(isEn ? 'en-US' : 'zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
}) ?? '';

const excerpt = tldr || description || '';
---

<article class={`card${pinned ? ' card--pinned' : ''}${featured ? ' card--featured' : ''}`}>
  <div class="card-header">
    <div class="card-badges">
      {pinned && <span class="badge badge-pinned">置頂</span>}
      <a href={catHref} class="badge badge-cat">{category}</a>
      {type && <span class="badge badge-type" data-type={type}>{type}</span>}
    </div>
    <div class="card-meta">
      {date && <time class="card-date">{dateStr}</time>}
      {readingTime && <span class="card-rt">{readingTime} 分鐘</span>}
    </div>
  </div>

  <h2 class="card-title">
    <a href={postHref}>{title}</a>
  </h2>

  {excerpt && <p class="card-excerpt">{excerpt}</p>}

  {tags.length > 0 && (
    <div class="card-tags">
      {tags.map((tag) => (
        <a href={tagHref(tag)} class="card-tag">#{tag}</a>
      ))}
    </div>
  )}

  {type === 'case-study' && (github || url) && (
    <div class="card-links">
      {github && (
        <a href={github} target="_blank" rel="noopener" class="card-link">
          GitHub ↗
        </a>
      )}
      {url && (
        <a href={url} target="_blank" rel="noopener" class="card-link">
          網站 ↗
        </a>
      )}
    </div>
  )}
</article>

<style>
  .card {
    background: var(--bg-secondary);
    border: 0.5px solid var(--separator);
    border-radius: var(--radius-lg);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--separator));
  }
  .card--pinned {
    border-color: #ff3b30;
    border-width: 1.5px;
  }
  .card--pinned:hover {
    border-color: #ff3b30;
  }

  .card--featured {
    padding: 28px 32px;
    border-width: 1px;
    border-color: color-mix(in srgb, var(--accent) 20%, var(--separator));
  }
  .card--featured .card-title {
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.25;
  }
  .card--featured .card-excerpt {
    font-size: 15px;
    -webkit-line-clamp: 3;
    line-height: 1.7;
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }

  .card-badges {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .card-date {
    font-size: 12px;
    color: var(--label-tertiary);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .card-rt {
    font-size: 12px;
    color: var(--label-tertiary);
    white-space: nowrap;
  }
  .card-rt::before { content: '· '; }

  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 0.15s;
  }
  .badge:hover { opacity: 0.75; }

  .badge-pinned {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
    border: 0.5px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .badge-cat {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border: 0.5px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }

  /* type badge — default */
  .badge-type {
    background: color-mix(in srgb, var(--color-green, #30d158) 10%, transparent);
    color: var(--color-green, #30d158);
    border: 0.5px solid color-mix(in srgb, var(--color-green, #30d158) 25%, transparent);
  }

  /* type-specific overrides */
  .badge-type[data-type="debug"]       { background:color-mix(in srgb,#ff5f57 10%,transparent); color:#ff5f57; border-color:color-mix(in srgb,#ff5f57 25%,transparent); }
  .badge-type[data-type="how-to"]      { background:color-mix(in srgb,var(--color-green) 10%,transparent); color:var(--color-green); border-color:color-mix(in srgb,var(--color-green) 25%,transparent); }
  .badge-type[data-type="listicle"]    { background:color-mix(in srgb,#ff9f0a 10%,transparent); color:#ff9f0a; border-color:color-mix(in srgb,#ff9f0a 25%,transparent); }
  .badge-type[data-type="explainer"]   { background:color-mix(in srgb,var(--accent) 10%,transparent); color:var(--accent); border-color:color-mix(in srgb,var(--accent) 25%,transparent); }
  .badge-type[data-type="case-study"]  { background:color-mix(in srgb,#bf5af2 10%,transparent); color:#bf5af2; border-color:color-mix(in srgb,#bf5af2 25%,transparent); }
  .badge-type[data-type="comparison"]  { background:color-mix(in srgb,#64d2ff 10%,transparent); color:#64d2ff; border-color:color-mix(in srgb,#64d2ff 25%,transparent); }
  .badge-type[data-type="research"]    { background:color-mix(in srgb,#ffd60a 10%,transparent); color:#b8960a; border-color:color-mix(in srgb,#ffd60a 25%,transparent); }
  .badge-type[data-type="newsjacking"] { background:color-mix(in srgb,#ff6b81 10%,transparent); color:#ff6b81; border-color:color-mix(in srgb,#ff6b81 25%,transparent); }
  .badge-type[data-type="deep-dive"]   { background:color-mix(in srgb,var(--accent) 15%,transparent); color:var(--accent); border-color:color-mix(in srgb,var(--accent) 30%,transparent); }

  /* Title */
  .card-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin: 0;
  }
  .card-title a {
    color: var(--label);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-title a:hover { color: var(--accent); }

  /* Excerpt */
  .card-excerpt {
    font-size: 14px;
    color: var(--label-secondary);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Tags */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
  .card-tag {
    font-size: 12px;
    color: var(--label-tertiary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-tag:hover { color: var(--accent); }

  /* Case-study links */
  .card-links {
    display: flex;
    gap: 8px;
    margin-top: 2px;
  }
  .card-link {
    font-size: 12px;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    padding: 3px 10px;
    border: 0.5px solid color-mix(in srgb, var(--accent) 30%, transparent);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    transition: background 0.15s;
  }
  .card-link:hover {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
  }
</style>
