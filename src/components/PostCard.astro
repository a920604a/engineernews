---
import type { Lang } from '../i18n/ui';

interface Props {
  id: string;
  title: string;
  date: Date;
  category: string;
  tags: string[];
  description?: string;
  tldr?: string;
  type?: string;
  pinned?: boolean;
  readingTime?: number;
  lang?: Lang;
  kind?: 'post' | 'project';
}

const {
  id, title, date, category, tags,
  description, tldr, type, pinned = false,
  readingTime, lang = 'zh-TW', kind = 'post',
} = Astro.props;

const isEn = lang === 'en';
const postHref = kind === 'project'
  ? (isEn ? `/en/projects/${id}` : `/projects/${id}`)
  : (isEn ? `/en/posts/${id}` : `/posts/${id}`);
const catHref  = isEn ? `/en/categories/${category}` : `/categories/${category}`;
const tagHref  = (t: string) => isEn ? `/en/tags/${t}` : `/tags/${t}`;

const dateStr = date?.toLocaleDateString(isEn ? 'en-US' : 'zh-TW', {
  year: 'numeric', month: 'long', day: 'numeric',
}) ?? '';

const excerpt = tldr || description || '';
---

<article class="card">
  <div class="card-header">
    <div class="card-badges">
      {pinned && <span class="badge badge-pinned">置頂</span>}
      <a href={catHref} class="badge badge-cat">{category}</a>
      {kind === 'project' && <span class="badge badge-project">專案</span>}
      {type && <span class="badge badge-type">{type}</span>}
    </div>
    <div class="card-meta">
      {date && <time class="card-date">{dateStr}</time>}
      {readingTime && <span class="card-rt">{readingTime} 分鐘</span>}
    </div>
  </div>

  <h2 class="card-title">
    <a href={postHref}>{title}</a>
  </h2>

  {excerpt && <p class="card-excerpt">{excerpt}</p>}

  {tags.length > 0 && (
    <div class="card-tags">
      {tags.map((tag) => (
        <a href={tagHref(tag)} class="card-tag">#{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .card {
    background: var(--bg-secondary);
    border: 0.5px solid var(--separator);
    border-radius: var(--radius-lg);
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 30%, var(--separator));
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-wrap: wrap;
  }

  .card-badges {
    display: flex;
    align-items: center;
    gap: 5px;
    flex-wrap: wrap;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .card-date {
    font-size: 12px;
    color: var(--label-tertiary);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .card-rt {
    font-size: 12px;
    color: var(--label-tertiary);
    white-space: nowrap;
  }
  .card-rt::before { content: '· '; }

  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-decoration: none;
    text-transform: uppercase;
    transition: opacity 0.15s;
  }
  .badge:hover { opacity: 0.75; }

  .badge-pinned {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
    border: 0.5px solid color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .badge-cat {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border: 0.5px solid color-mix(in srgb, var(--accent) 25%, transparent);
  }
  .badge-type {
    background: color-mix(in srgb, var(--color-green, #30d158) 10%, transparent);
    color: var(--color-green, #30d158);
    border: 0.5px solid color-mix(in srgb, var(--color-green, #30d158) 25%, transparent);
  }
  .badge-project {
    background: color-mix(in srgb, #ff9f0a 10%, transparent);
    color: #ff9f0a;
    border: 0.5px solid color-mix(in srgb, #ff9f0a 25%, transparent);
  }

  /* Title */
  .card-title {
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.35;
    margin: 0;
  }
  .card-title a {
    color: var(--label);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-title a:hover { color: var(--accent); }

  /* Excerpt */
  .card-excerpt {
    font-size: 14px;
    color: var(--label-secondary);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Tags */
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 2px;
  }
  .card-tag {
    font-size: 12px;
    color: var(--label-tertiary);
    text-decoration: none;
    transition: color 0.15s;
  }
  .card-tag:hover { color: var(--accent); }
</style>
