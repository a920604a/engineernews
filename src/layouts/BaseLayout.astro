---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Engineer News - 技術決策即文件" } = Astro.props;
const { currentLocale } = Astro;
---

<!doctype html>
<html lang={currentLocale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Engineer News</title>
		<style is:global>
			:root {
				/* Apple Semantic Colors (Dark Mode) */
				--bg-color: #000000;
				--secondary-bg: #1c1c1e;
				--label-primary: #ffffff;
				--label-secondary: #8e8e93;
				--accent-color: #0a84ff;
				--separator: #38383a;
				--card-bg: rgba(28, 28, 30, 0.8);
				--glass-bg: rgba(255, 255, 255, 0.05);
			}

			@media (prefers-color-scheme: light) {
				:root {
					--bg-color: #f2f2f7;
					--secondary-bg: #ffffff;
					--label-primary: #000000;
					--label-secondary: #8e8e93;
					--accent-color: #007aff;
					--separator: #c6c6c8;
					--card-bg: rgba(255, 255, 255, 0.8);
					--glass-bg: rgba(0, 0, 0, 0.05);
				}
			}

			body {
				background-color: var(--bg-color);
				color: var(--label-primary);
				/* Apple System Font Stack */
				font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
				margin: 0;
				padding: 0;
				line-height: 1.47059;
				font-weight: 400;
				letter-spacing: -0.022em;
				-webkit-font-smoothing: antialiased;
			}

			main {
				max-width: 980px;
				margin: 0 auto;
				padding: 0 20px;
			}

			header {
				position: sticky;
				top: 0;
				z-index: 100;
				background: var(--card-bg);
				backdrop-filter: saturate(180%) blur(20px);
				border-bottom: 0.5px solid var(--separator);
				margin-bottom: 40px;
			}

			.nav-container {
				max-width: 980px;
				margin: 0 auto;
				height: 52px;
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0 20px;
			}

			nav a {
				color: var(--label-primary);
				text-decoration: none;
				font-size: 14px;
				font-weight: 400;
				opacity: 0.8;
				transition: opacity 0.2s;
			}

			nav a:hover {
				opacity: 1;
			}

			.card {
				background: var(--secondary-bg);
				border-radius: 18px;
				padding: 24px;
				margin-bottom: 24px;
				transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
				border: 0.5px solid var(--separator);
			}

			h1 { font-size: 40px; font-weight: 700; letter-spacing: -0.009em; margin-bottom: 0.5em; }
			h2 { font-size: 24px; font-weight: 600; letter-spacing: 0.007em; }
			
			.tag {
				display: inline-block;
				padding: 4px 10px;
				background: var(--glass-bg);
				border-radius: 100px;
				font-size: 12px;
				font-weight: 500;
				color: var(--accent-color);
				margin-right: 8px;
			}

			.btn-primary {
				background-color: var(--accent-color);
				color: white;
				padding: 8px 16px;
				border-radius: 980px;
				font-size: 14px;
				font-weight: 500;
				text-decoration: none;
				display: inline-block;
			}
		</style>
	</head>
	<body>
		<header>
			<div class="nav-container">
				<nav style="display: flex; gap: 24px; align-items: center;">
					<a href="/" style="font-weight: 600; opacity: 1;">Engineer News</a>
					<a href="/projects">作品集</a>
				</nav>
				<div>
					<a href={currentLocale === 'en' ? '/' : '/en'} class="btn-primary">
						{currentLocale === 'en' ? '繁體中文' : 'English'}
					</a>
				</div>
			</div>
		</header>
		<main>
			<slot />
			<footer style="margin-top: 80px; padding-bottom: 40px; text-align: center; color: var(--label-secondary); font-size: 12px;">
				&copy; {new Date().getFullYear()} Engineer News. Designed with Apple HIG in mind.
			</footer>
		</main>
	</body>
</html>
