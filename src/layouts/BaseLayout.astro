---
import { getLangFromUrl, useTranslations, getLangSwitchUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  jsonLd?: object;
  ogImage?: string;
}

const { title, description, jsonLd, ogImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteName = 'Engineer News';
const siteDescription = description ?? t('site.tagline');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://engineer-news.pages.dev');
const switchURL = getLangSwitchUrl(Astro.url, lang);
const isEn = lang === 'en';

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": siteName,
  "description": siteDescription,
  "url": canonicalURL.origin,
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={siteDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {siteName}</title>

    <link rel="alternate" hreflang="zh-TW" href={`${canonicalURL.origin}${isEn ? Astro.url.pathname.replace(/^\/en/, '') || '/' : Astro.url.pathname}`} />
    <link rel="alternate" hreflang="en" href={`${canonicalURL.origin}/en${isEn ? Astro.url.pathname : Astro.url.pathname}`} />

    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={siteDescription} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd ?? siteJsonLd)} />

    <style is:global>
      @import '@fontsource/noto-sans-tc/400.css';
      @import '@fontsource/noto-sans-tc/500.css';
      @import '@fontsource/noto-sans-tc/700.css';
      @import '@fontsource/noto-sans-tc/900.css';

      /* ─── Theme Variables ─────────────────────────────── */

      /* Default: Apple Dark */
      :root {
        --bg: #000000;
        --bg-secondary: #1c1c1e;
        --bg-tertiary: #2c2c2e;
        --label: #ffffff;
        --label-secondary: rgba(235,235,245,0.6);
        --label-tertiary: rgba(235,235,245,0.3);
        --separator: rgba(84,84,88,0.65);
        --accent: #0a84ff;
        --accent-hover: #409cff;
        --heading-accent: #ff6b81;
        --color-green: #30d158;
        --card-bg: rgba(28,28,30,0.8);
        --glass: rgba(255,255,255,0.06);
        --shadow-md: 0 4px 20px rgba(0,0,0,0.6);
        --radius-sm: 8px; --radius-md: 12px;
        --radius-lg: 18px; --radius-full: 9999px;
      }

      /* Apple Light */
      :root[data-theme="light"] {
        --bg: #f5f5f7;
        --bg-secondary: #ffffff;
        --bg-tertiary: #e5e5ea;
        --label: #1d1d1f;
        --label-secondary: rgba(60,60,67,0.6);
        --label-tertiary: rgba(60,60,67,0.3);
        --separator: rgba(60,60,67,0.18);
        --accent: #007aff;
        --accent-hover: #0056d6;
        --heading-accent: #e8416a;
        --color-green: #34c759;
        --card-bg: rgba(255,255,255,0.9);
        --glass: rgba(0,0,0,0.04);
        --shadow-md: 0 2px 16px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.06);
      }

      /* Nord — Arctic blue-grey */
      :root[data-theme="nord"] {
        --bg: #2e3440;
        --bg-secondary: #3b4252;
        --bg-tertiary: #434c5e;
        --label: #eceff4;
        --label-secondary: rgba(216,222,233,0.75);
        --label-tertiary: rgba(216,222,233,0.4);
        --separator: rgba(76,86,106,0.8);
        --accent: #88c0d0;
        --accent-hover: #81a1c1;
        --heading-accent: #bf616a;
        --color-green: #a3be8c;
        --card-bg: rgba(59,66,82,0.85);
        --glass: rgba(236,239,244,0.05);
        --shadow-md: 0 4px 20px rgba(0,0,0,0.4);
      }

      /* Catppuccin Mocha — warm pastel dark */
      :root[data-theme="catppuccin"] {
        --bg: #1e1e2e;
        --bg-secondary: #313244;
        --bg-tertiary: #45475a;
        --label: #cdd6f4;
        --label-secondary: rgba(186,194,222,0.75);
        --label-tertiary: rgba(186,194,222,0.4);
        --separator: rgba(69,71,90,0.9);
        --accent: #89b4fa;
        --accent-hover: #b4befe;
        --heading-accent: #f38ba8;
        --color-green: #a6e3a1;
        --card-bg: rgba(49,50,68,0.85);
        --glass: rgba(205,214,244,0.05);
        --shadow-md: 0 4px 20px rgba(0,0,0,0.5);
      }

      /* Tokyo Night — purple-blue */
      :root[data-theme="tokyo"] {
        --bg: #1a1b2e;
        --bg-secondary: #24253a;
        --bg-tertiary: #2d2f45;
        --label: #c0caf5;
        --label-secondary: rgba(154,165,206,0.8);
        --label-tertiary: rgba(154,165,206,0.4);
        --separator: rgba(65,72,104,0.8);
        --accent: #7aa2f7;
        --accent-hover: #bb9af7;
        --heading-accent: #f7768e;
        --color-green: #9ece6a;
        --card-bg: rgba(36,37,58,0.88);
        --glass: rgba(192,202,245,0.05);
        --shadow-md: 0 4px 20px rgba(0,0,0,0.55);
      }

      /* System light fallback */
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          --bg: #f5f5f7; --bg-secondary: #ffffff; --bg-tertiary: #e5e5ea;
          --label: #1d1d1f; --label-secondary: rgba(60,60,67,0.6);
          --label-tertiary: rgba(60,60,67,0.3); --separator: rgba(60,60,67,0.18);
          --accent: #007aff; --accent-hover: #0056d6;
          --heading-accent: #e8416a; --color-green: #34c759;
          --card-bg: rgba(255,255,255,0.9); --glass: rgba(0,0,0,0.04);
          --shadow-md: 0 2px 16px rgba(0,0,0,0.08), 0 1px 3px rgba(0,0,0,0.06);
        }
      }

      /* ─── Base ────────────────────────────────────────── */
      *, *::before, *::after { box-sizing: border-box; }

      body {
        background: var(--bg);
        color: var(--label);
        font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Helvetica Neue', Arial, sans-serif;
        font-size: 17px;
        line-height: 1.8;
        letter-spacing: 0.01em;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        margin: 0;
        transition: background 0.25s, color 0.25s;
      }

      main { max-width: 720px; margin: 0 auto; padding: 0 24px 96px; }

      /* ─── Nav ─────────────────────────────────────────── */
      .site-header {
        position: sticky; top: 0; z-index: 100;
        background: var(--card-bg);
        backdrop-filter: saturate(180%) blur(24px);
        -webkit-backdrop-filter: saturate(180%) blur(24px);
        border-bottom: 0.5px solid var(--separator);
      }

      .nav-inner {
        max-width: 720px; margin: 0 auto; padding: 0 20px;
        height: 48px; display: flex; align-items: center;
        justify-content: space-between; gap: 16px;
      }

      .nav-brand {
        font-size: 15px; font-weight: 600; color: var(--label);
        text-decoration: none; letter-spacing: -0.01em; white-space: nowrap;
      }

      .nav-links { display: flex; align-items: center; gap: 4px; flex: 1; }

      .nav-link {
        font-size: 14px; color: var(--label-secondary); text-decoration: none;
        padding: 5px 10px; border-radius: var(--radius-sm);
        transition: color 0.15s, background 0.15s; white-space: nowrap;
      }
      .nav-link:hover { color: var(--label); background: var(--glass); }

      .lang-btn {
        font-size: 13px; font-weight: 500; color: var(--accent);
        text-decoration: none; padding: 5px 12px; border-radius: var(--radius-full);
        border: 1px solid var(--accent); transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .lang-btn:hover { background: var(--accent); color: #fff; }

      /* ─── Theme Picker ────────────────────────────────── */
      .theme-picker { position: relative; }

      .theme-btn {
        display: flex; align-items: center; gap: 5px;
        padding: 4px 10px; border-radius: var(--radius-full);
        border: 0.5px solid var(--separator); background: transparent;
        color: var(--label-secondary); font-size: 12px; font-weight: 500;
        cursor: pointer; transition: background 0.15s, color 0.15s;
        white-space: nowrap;
      }
      .theme-btn:hover { background: var(--glass); color: var(--label); }

      .theme-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: var(--accent); flex-shrink: 0;
      }

      .theme-menu {
        display: none; position: absolute; right: 0; top: calc(100% + 6px);
        background: var(--bg-secondary); border: 0.5px solid var(--separator);
        border-radius: var(--radius-md); padding: 6px;
        min-width: 160px; box-shadow: var(--shadow-md);
        z-index: 200;
      }
      .theme-menu.open { display: block; }

      .theme-option {
        display: flex; align-items: center; gap: 10px;
        width: 100%; padding: 8px 12px; border-radius: 8px;
        background: transparent; border: none; cursor: pointer;
        font-size: 13px; font-weight: 500; color: var(--label-secondary);
        text-align: left; transition: background 0.12s, color 0.12s;
      }
      .theme-option:hover { background: var(--glass); color: var(--label); }
      .theme-option.active { color: var(--label); }

      .theme-swatch {
        width: 14px; height: 14px; border-radius: 50%;
        flex-shrink: 0; border: 1.5px solid var(--separator);
      }

      /* ─── Typography ──────────────────────────────────── */
      h1 { font-size: clamp(28px, 5vw, 36px); font-weight: 900; letter-spacing: -0.02em; line-height: 1.15; margin: 0 0 0.4em; }
      h2 { font-size: 22px; font-weight: 800; letter-spacing: -0.01em; line-height: 1.3; margin: 0 0 0.25em; }
      h3 { font-size: 18px; font-weight: 700; line-height: 1.4; margin: 0 0 0.25em; }
      a { color: var(--accent); }
      a:hover { color: var(--accent-hover); }

      /* ─── Card ────────────────────────────────────────── */
      .card {
        background: var(--bg-secondary); border: 0.5px solid var(--separator);
        border-radius: var(--radius-lg); padding: 20px 24px;
        transition: box-shadow 0.2s, transform 0.2s;
      }
      .card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }

      /* ─── Tags ────────────────────────────────────────── */
      .tags { display: flex; flex-wrap: wrap; gap: 6px; }
      .tag {
        display: inline-flex; align-items: center; padding: 3px 10px;
        background: var(--glass); border: 0.5px solid var(--separator);
        border-radius: var(--radius-full); font-size: 12px; font-weight: 500;
        color: var(--accent); text-decoration: none; transition: background 0.15s;
      }
      .tag:hover { background: color-mix(in srgb, var(--accent) 12%, transparent); }

      /* ─── Badge ───────────────────────────────────────── */
      .badge {
        display: inline-flex; align-items: center; padding: 2px 8px;
        border-radius: var(--radius-full); font-size: 11px; font-weight: 600;
        letter-spacing: 0.02em; text-transform: uppercase; text-decoration: none;
      }
      .badge-type {
        background: color-mix(in srgb, var(--accent) 15%, transparent);
        color: var(--accent);
      }

      /* ─── Feed ────────────────────────────────────────── */
      .feed { display: flex; flex-direction: column; }

      /* ─── Footer ──────────────────────────────────────── */
      .site-footer {
        text-align: center; padding: 32px 20px;
        color: var(--label-tertiary); font-size: 13px;
        border-top: 0.5px solid var(--separator); margin-top: 60px;
      }

      /* ─── Prose ───────────────────────────────────────── */
      .prose { font-size: 17px; line-height: 1.8; color: var(--label); }
      .prose > * + * { margin-top: 1.25rem; }
      .prose p { margin: 0 0 1.25rem; }

      .prose h2 {
        font-size: 22px; font-weight: 800; margin-top: 3rem; margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--heading-accent);
        color: var(--label); letter-spacing: -0.01em; line-height: 1.3;
      }
      .prose h3 {
        font-size: 18px; font-weight: 700; margin-top: 2.25rem; margin-bottom: 0.75rem;
        color: var(--label); letter-spacing: -0.005em;
      }
      .prose h3::before {
        content: ''; display: inline-block;
        width: 4px; height: 1em; margin-right: 8px;
        background: var(--heading-accent); border-radius: 2px;
        vertical-align: middle; position: relative; top: -1px;
      }

      .prose pre {
        background: #0d1117; border: 0.5px solid var(--separator);
        border-radius: var(--radius-md); padding: 16px 20px;
        overflow-x: auto; font-size: 14px; line-height: 1.65;
      }
      .prose code { font-family: 'SF Mono', ui-monospace, Menlo, Monaco, 'Cascadia Code', monospace; font-size: 0.875em; }
      .prose :not(pre) > code {
        background: color-mix(in srgb, var(--accent) 10%, transparent);
        border: 0.5px solid color-mix(in srgb, var(--accent) 25%, transparent);
        border-radius: 5px; padding: 2px 6px; color: var(--accent);
      }
      .prose blockquote {
        border-left: 3px solid var(--heading-accent); margin: 1.5rem 0;
        padding: 0.75rem 1.25rem;
        background: color-mix(in srgb, var(--heading-accent) 6%, transparent);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        color: var(--label-secondary); font-style: italic;
      }
      .prose ul, .prose ol { padding-left: 1.5rem; margin: 0 0 1.25rem; }
      .prose li { margin-bottom: 0.4rem; }
      .prose a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
      .prose a:hover { color: var(--accent-hover); }
      .prose img { max-width: 100%; border-radius: var(--radius-md); }
      .prose hr { border: none; border-top: 0.5px solid var(--separator); margin: 2.5rem 0; }
      .prose table { width: 100%; border-collapse: collapse; font-size: 15px; margin: 1.5rem 0; }
      .prose th, .prose td { padding: 10px 14px; border: 0.5px solid var(--separator); }
      .prose th { background: var(--glass); font-weight: 700; color: var(--label); }
      .prose tr:hover td { background: var(--glass); }

      /* ─── macOS Code Block ────────────────────────────── */
      .prose pre {
        position: relative;
        padding-top: 36px !important;
      }
      .prose pre::before {
        content: '';
        position: absolute;
        top: 12px; left: 16px;
        width: 12px; height: 12px;
        border-radius: 50%;
        background: #ff5f57;
        box-shadow: 20px 0 0 #febc2e, 40px 0 0 #28c840;
      }

      /* ─── Reading Progress Bar ────────────────────────── */
      #reading-progress {
        position: fixed; top: 0; left: 0; z-index: 9999;
        height: 2px; width: 0%;
        background: var(--accent);
        transition: width 0.1s linear;
        pointer-events: none;
      }

      /* ─── Table of Contents ───────────────────────────── */
      .toc-block {
        background: var(--bg-secondary);
        border: 0.5px solid var(--separator);
        border-left: 3px solid var(--accent);
        border-radius: var(--radius-md);
        padding: 14px 18px;
        margin-bottom: 32px;
        font-size: 14px;
      }
      .toc-block summary {
        font-size: 11px; font-weight: 600; letter-spacing: 0.05em;
        text-transform: uppercase; color: var(--label-secondary);
        cursor: pointer; user-select: none; margin-bottom: 0;
      }
      .toc-block[open] summary { margin-bottom: 10px; }
      .toc-block nav ol {
        margin: 0; padding-left: 1.2em; display: flex; flex-direction: column; gap: 4px;
      }
      .toc-block nav li { line-height: 1.4; }
      .toc-block nav a {
        color: var(--label-secondary); text-decoration: none;
        transition: color 0.15s;
      }
      .toc-block nav a:hover { color: var(--accent); }

      /* ─── Callout Boxes ───────────────────────────────── */
      .callout {
        border-radius: var(--radius-md);
        padding: 14px 18px; margin: 1.5rem 0;
        border: 0.5px solid var(--separator);
        font-size: 15px; line-height: 1.6;
      }
      .callout-title {
        font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
        text-transform: uppercase; margin-bottom: 6px;
      }
      .callout-info    { background: color-mix(in srgb, var(--accent) 8%, transparent); border-left: 3px solid var(--accent); }
      .callout-info    .callout-title { color: var(--accent); }
      .callout-warning { background: color-mix(in srgb, #febc2e 10%, transparent); border-left: 3px solid #febc2e; }
      .callout-warning .callout-title { color: #febc2e; }
      .callout-success { background: color-mix(in srgb, var(--color-green) 8%, transparent); border-left: 3px solid var(--color-green); }
      .callout-success .callout-title { color: var(--color-green); }
      .callout-danger  { background: color-mix(in srgb, #ff5f57 10%, transparent); border-left: 3px solid #ff5f57; }
      .callout-danger  .callout-title { color: #ff5f57; }

      /* ─── Mermaid Zoom Wrapper ───────────────────────────── */
      .mermaid-wrap {
        position: relative;
        border: 1px solid var(--separator);
        border-radius: var(--radius-md);
        overflow: hidden;
        margin: 1.5rem 0;
        background: var(--bg-secondary);
      }
      .mermaid-toolbar {
        display: flex;
        gap: 4px;
        padding: 6px 10px;
        border-bottom: 1px solid var(--separator);
        background: var(--bg-tertiary);
      }
      .mermaid-zoom-btn {
        width: 28px; height: 28px;
        border: 1px solid var(--separator);
        border-radius: 6px;
        background: var(--bg-secondary);
        color: var(--label);
        cursor: pointer;
        font-size: 15px;
        line-height: 1;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
      }
      .mermaid-zoom-btn:hover { background: var(--glass); }
      .mermaid-viewport {
        overflow: hidden;
        cursor: grab;
        user-select: none;
        padding: 16px;
        min-height: 200px;
        height: 420px;
      }
      .mermaid-viewport:active { cursor: grabbing; }
      .mermaid-viewport .mermaid {
        display: inline-block;
        transform-origin: top left;
        will-change: transform;
      }
      /* fullscreen mode */
      .mermaid-wrap:fullscreen,
      .mermaid-wrap:-webkit-full-screen {
        display: flex;
        flex-direction: column;
        background: var(--bg);
        border-radius: 0;
        border: none;
      }
      .mermaid-wrap:fullscreen .mermaid-viewport,
      .mermaid-wrap:-webkit-full-screen .mermaid-viewport {
        flex: 1;
        overflow: auto;
      }
    </style>
  </head>
  <body>
    <!-- Anti-flash: apply theme before paint -->
    <script is:inline>
      (function () {
        var t = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <div id="reading-progress"></div>

    <header class="site-header" data-pagefind-ignore>
      <div class="nav-inner">
        <a class="nav-brand" href={isEn ? '/en' : '/'}>{t('nav.home')}</a>
        <nav class="nav-links">
          <a class="nav-link" href={isEn ? '/en/categories' : '/categories'}>{t('nav.tags')}</a>
          <a class="nav-link" href={isEn ? '/en/projects' : '/projects'}>{t('nav.projects')}</a>
        </nav>
        <div style="display:flex; align-items:center; gap:8px;">
          <!-- Search -->
          <a href="/search" aria-label="搜尋" style="display:flex; align-items:center; justify-content:center; width:32px; height:32px; border-radius:var(--radius-sm); color:var(--label-secondary); text-decoration:none; transition:background 0.15s, color 0.15s;" onmouseover="this.style.background='var(--glass)';this.style.color='var(--label)'" onmouseout="this.style.background='';this.style.color='var(--label-secondary)'">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          </a>
          <!-- Theme picker -->
          <div class="theme-picker">
            <button class="theme-btn" id="theme-btn" aria-label="Select theme">
              <span class="theme-dot"></span>
              <span id="theme-label">Theme</span>
            </button>
            <div class="theme-menu" id="theme-menu">
              <button class="theme-option" data-theme="dark">
                <span class="theme-swatch" style="background:#1c1c1e; border-color:#3a3a3c;"></span>
                Apple Dark
              </button>
              <button class="theme-option" data-theme="light">
                <span class="theme-swatch" style="background:#f2f2f7; border-color:#c6c6c8;"></span>
                Apple Light
              </button>
              <button class="theme-option" data-theme="nord">
                <span class="theme-swatch" style="background:#3b4252; border-color:#88c0d0;"></span>
                Nord
              </button>
              <button class="theme-option" data-theme="catppuccin">
                <span class="theme-swatch" style="background:#313244; border-color:#89b4fa;"></span>
                Catppuccin
              </button>
              <button class="theme-option" data-theme="tokyo">
                <span class="theme-swatch" style="background:#24253a; border-color:#7aa2f7;"></span>
                Tokyo Night
              </button>
            </div>
          </div>
          <a class="lang-btn" href={switchURL}>{t('lang.switch')}</a>
        </div>
      </div>
    </header>

    <script is:inline>
      (function () {
        var labels = {
          dark: 'Apple Dark', light: 'Apple Light',
          nord: 'Nord', catppuccin: 'Catppuccin', tokyo: 'Tokyo Night'
        };

        function applyTheme(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);
          var lbl = document.getElementById('theme-label');
          if (lbl) lbl.textContent = labels[theme] || theme;
          document.querySelectorAll('.theme-option').forEach(function(btn) {
            btn.classList.toggle('active', btn.dataset.theme === theme);
          });
        }

        document.addEventListener('DOMContentLoaded', function () {
          var current = localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          applyTheme(current);

          var btn = document.getElementById('theme-btn');
          var menu = document.getElementById('theme-menu');

          btn.addEventListener('click', function (e) {
            e.stopPropagation();
            menu.classList.toggle('open');
          });

          document.addEventListener('click', function () {
            menu.classList.remove('open');
          });

          document.querySelectorAll('.theme-option').forEach(function (opt) {
            opt.addEventListener('click', function (e) {
              e.stopPropagation();
              applyTheme(opt.dataset.theme);
              menu.classList.remove('open');
            });
          });
        });
      })();
    </script>

    <main data-pagefind-body>
      <slot />
    </main>

    <footer class="site-footer" data-pagefind-ignore>
      &copy; {new Date().getFullYear()} Engineer News &mdash; {t('footer.built')}
    </footer>

    <!-- Reading Progress -->
    <script is:inline>
      (function () {
        var bar = document.getElementById('reading-progress');
        if (!bar) return;
        window.addEventListener('scroll', function () {
          var doc = document.documentElement;
          var scrolled = doc.scrollTop || document.body.scrollTop;
          var total = doc.scrollHeight - doc.clientHeight;
          bar.style.width = total > 0 ? (scrolled / total * 100) + '%' : '0%';
        }, { passive: true });
      })();
    </script>

    <!-- Mermaid client-side rendering -->
    <script src="https://cdn.jsdelivr.net/npm/mermaid@10.4.0/dist/mermaid.min.js"></script>
    <script is:inline>
      (function () {
        function log() { try { console.debug('[mermaid]'); } catch (e) {} }
        function initMermaidOnce() {
          try {
            if (!window.mermaid) { console.error('mermaid not loaded'); return; }
            // pick theme based on page theme
            var theme = document.documentElement.getAttribute('data-theme') === 'light' ? 'default' : 'dark';
            mermaid.initialize({ startOnLoad: false, theme: theme });

            // match various code block classnames
            var selectors = ['pre > code.language-mermaid', 'pre > code.lang-mermaid', 'code.language-mermaid', 'code.lang-mermaid', 'pre[data-language="mermaid"]'];
            var nodes = document.querySelectorAll(selectors.join(','));
            if (!nodes || nodes.length === 0) {
              // nothing to do
              return;
            }

            nodes.forEach(function (node) {
              // node may be a <code> inside <pre>, or the <pre> itself
              var pre = (node.tagName && node.tagName.toLowerCase() === 'pre') ? node : (node.parentElement && node.parentElement.tagName.toLowerCase() === 'pre' ? node.parentElement : null);
              var text = '';
              if (pre) {
                text = pre.textContent || '';
              } else if (node) {
                text = node.textContent || '';
              }

              var container = document.createElement('div');
              container.className = 'mermaid';
              container.textContent = text;

              // insert after pre (safer than replace)
              if (pre && pre.parentNode) {
                if (pre.nextSibling) pre.parentNode.insertBefore(container, pre.nextSibling);
                else pre.parentNode.appendChild(container);
                // hide original pre to keep semantics for copy/paste
                pre.style.display = 'none';
              } else if (node && node.parentNode) {
                if (node.nextSibling) node.parentNode.insertBefore(container, node.nextSibling);
                else node.parentNode.appendChild(container);
                node.style.display = 'none';
              }
            });

            // init mermaid on the newly created containers
            var mermaidEls = document.querySelectorAll('.mermaid');
            var initResult = mermaid.init(undefined, mermaidEls);
            var afterInit = function () {
              mermaidEls.forEach(addMermaidZoom);
            };
            if (initResult && typeof initResult.then === 'function') {
              initResult.then(afterInit).catch(function (e) { console.error('mermaid init error', e); });
            } else {
              // fallback for older versions
              setTimeout(afterInit, 100);
            }
          } catch (e) {
            console.error('Mermaid render failed', e);
          }
        }

        function addMermaidZoom(el) {
          if (el.closest('.mermaid-wrap')) return; // already wrapped
          var wrap = document.createElement('div');
          wrap.className = 'mermaid-wrap';

          var toolbar = document.createElement('div');
          toolbar.className = 'mermaid-toolbar';
          toolbar.innerHTML =
            '<button class="mermaid-zoom-btn" data-action="in" title="Zoom in">+</button>' +
            '<button class="mermaid-zoom-btn" data-action="out" title="Zoom out">−</button>' +
            '<button class="mermaid-zoom-btn" data-action="reset" title="Reset" style="font-size:11px">⊙</button>' +
            '<button class="mermaid-zoom-btn" data-action="fullscreen" title="Fullscreen" style="margin-left:auto;font-size:13px">⛶</button>';

          var vp = document.createElement('div');
          vp.className = 'mermaid-viewport';

          el.parentNode.insertBefore(wrap, el);
          wrap.appendChild(toolbar);
          wrap.appendChild(vp);
          vp.appendChild(el);

          var scale = 1, tx = 0, ty = 0;
          function apply() {
            el.style.transform = 'translate(' + tx + 'px,' + ty + 'px) scale(' + scale + ')';
          }
          function fitAndCenter() {
            var pad = 32;
            var vpW = vp.clientWidth - pad;
            var vpH = vp.clientHeight - pad;
            var elW = el.scrollWidth;
            var elH = el.scrollHeight;
            scale = 1;
            tx = Math.max(0, (vpW - elW) / 2);
            ty = Math.max(0, (vpH - elH) / 2);
            apply();
          }
          requestAnimationFrame(fitAndCenter);

          var fsBtn = toolbar.querySelector('[data-action="fullscreen"]');
          document.addEventListener('fullscreenchange', function () {
            var isFs = document.fullscreenElement === wrap;
            fsBtn.textContent = isFs ? '✕' : '⛶';
            fsBtn.title = isFs ? 'Exit fullscreen' : 'Fullscreen';
          });

          toolbar.addEventListener('click', function (e) {
            var btn = e.target.closest('[data-action]');
            if (!btn) return;
            var action = btn.dataset.action;
            if (action === 'in') scale = Math.min(scale * 1.3, 5);
            else if (action === 'out') scale = Math.max(scale / 1.3, 0.2);
            else if (action === 'reset') { fitAndCenter(); return; }
            else if (action === 'fullscreen') {
              if (!document.fullscreenElement) {
                wrap.requestFullscreen && wrap.requestFullscreen();
              } else {
                document.exitFullscreen && document.exitFullscreen();
              }
              return;
            }
            apply();
          });

          // wheel zoom centered on cursor position
          vp.addEventListener('wheel', function (e) {
            e.preventDefault();
            var rect = vp.getBoundingClientRect();
            var mx = e.clientX - rect.left - 16; // 16 = padding
            var my = e.clientY - rect.top - 16;
            var factor = e.deltaY < 0 ? 1.12 : 0.88;
            var newScale = Math.max(0.2, Math.min(5, scale * factor));
            tx = mx - (mx - tx) * (newScale / scale);
            ty = my - (my - ty) * (newScale / scale);
            scale = newScale;
            apply();
          }, { passive: false });

          // drag to pan
          var dragging = false, sx, sy, stx, sty;
          vp.addEventListener('pointerdown', function (e) {
            dragging = true; sx = e.clientX; sy = e.clientY; stx = tx; sty = ty;
            vp.setPointerCapture(e.pointerId);
          });
          vp.addEventListener('pointermove', function (e) {
            if (!dragging) return;
            tx = stx + e.clientX - sx;
            ty = sty + e.clientY - sy;
            apply();
          });
          vp.addEventListener('pointerup', function () { dragging = false; });
        }

        function loadMermaidIfNeeded(callback) {
          if (window.mermaid) return callback();
          // inject script dynamically to avoid Vite inlining/rewriting imports
          var CDN = 'https://cdn.jsdelivr.net/npm/mermaid@10.4.0/dist/mermaid.min.js';
          try {
            var existing = document.querySelector('script[src="' + CDN + '"]');
            if (existing) {
              existing.addEventListener('load', callback);
              existing.addEventListener('error', function () { console.error('Failed to load mermaid from CDN'); });
              return;
            }
            var s = document.createElement('script');
            s.src = CDN;
            s.async = true;
            s.crossOrigin = 'anonymous';
            s.onload = callback;
            s.onerror = function () { console.error('Failed to load mermaid from CDN', CDN); };
            document.head.appendChild(s);
          } catch (e) {
            console.error('Mermaid injection failed', e);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () { loadMermaidIfNeeded(initMermaidOnce); });
        } else {
          loadMermaidIfNeeded(initMermaidOnce);
        }
      })();
    </script>
  </body>
</html>
